generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recipe {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  servings    Int          @default(2)
  prepTime    String?
  totalTime   String?
  difficulty  String?
  cuisine     String?
  tags        String[]
  sourceUrl   String?
  language    String       @default("en")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ingredients Ingredient[]
  steps       Step[]

  @@index([language])
  @@index([sourceUrl])
  @@index([title])
  @@index([createdAt])
}

model Ingredient {
  id       Int     @id @default(autoincrement())
  name     String
  amount   String?
  unit     String?
  recipeId Int
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Step {
  id          Int     @id @default(autoincrement())
  stepNumber  Int
  instruction String
  imageUrl    String?
  recipeId    Int
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}
